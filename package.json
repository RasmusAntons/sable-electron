{
  "name": "sable-electron",
  "version": "0.0.1",
  "description": "Electron wrapper for the Sable matrix client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:sable": "cd sable && pnpm i && pnpm build && cp -r public/res/ dist/public/",
    "build:electron": "electron-builder",
    "build": "pnpm run build:sable && pnpm run build:electron",
    "pack": "electron-builder --dir"
  },
  "author": "Rasmus Antons <mail@rasmusantons.de>",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "sable/dist/**/*"
    ],
    "extraResources": [
      "favicon.png",
      "icon.png",
      "tray-icon.png"
    ],
    "linux": {
      "icon": "favicon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Chat"
    }
  }
}
